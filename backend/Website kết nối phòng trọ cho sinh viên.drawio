        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n\n&#39; ================= USER =================\nclass User {\n  id: String\n  email: String\n  password: String\n  fullName: String\n  phone: String\n  avatar: String\n  role: RoleEnum\n  isVerified: boolean\n  isActive: boolean\n  provider: String\n  createdAt: LocalDateTime\n}\n\n&#39; ================= ROOM =================\nclass Room {\n  id: String\n  landlordId: String\n  address: String\n  area: double\n  price: double\n  amenityIds: List&lt;String&gt;\n  images: List&lt;String&gt;\n  location: GeoJsonPoint\n  createdAt: LocalDateTime\n}\n\nclass Amenity {\n  id: String\n  name: String\n}\n\nRoom \&quot;1\&quot; -- \&quot;*\&quot; Amenity : has\n\n&#39; ================= POST =================\nclass Post {\n  id: String\n  roomId: String\n  landlordId: String\n  title: String\n  description: String\n  price: double\n  status: PostStatus\n  isBoosted: boolean\n  viewCount: int\n  createdAt: LocalDateTime\n  updatedAt: LocalDateTime\n}\n\nRoom \&quot;1\&quot; -- \&quot;*\&quot; Post\nUser \&quot;1\&quot; -- \&quot;*\&quot; Post : landlord\n\n&#39; ================= BOOKING =================\nclass Booking {\n  id: String\n  userId: String\n  landlordId: String\n  postId: String\n  bookingTime: LocalDateTime\n  status: BookingStatus\n  createdAt: LocalDateTime\n}\n\nUser \&quot;1\&quot; -- \&quot;*\&quot; Booking\nPost \&quot;1\&quot; -- \&quot;*\&quot; Booking\n\n&#39; ================= FAVORITE =================\nclass Favorite {\n  id: String\n  userId: String\n  roomId: String\n  createdAt: LocalDateTime\n}\n\nUser \&quot;1\&quot; -- \&quot;*\&quot; Favorite\nRoom \&quot;1\&quot; -- \&quot;*\&quot; Favorite\n\n&#39; ================= MESSAGE =================\nclass Message {\n  id: String\n  senderId: String\n  receiverId: String\n  content: String\n  createdAt: LocalDateTime\n}\n\nUser \&quot;1\&quot; -- \&quot;*\&quot; Message : sender\nUser \&quot;1\&quot; -- \&quot;*\&quot; Message : receiver\n\n&#39; ================= REVIEW =================\nclass Review {\n  id: String\n  userId: String\n  postId: String\n  rating: int\n  comment: String\n  createdAt: LocalDateTime\n}\n\nUser \&quot;1\&quot; -- \&quot;*\&quot; Review\nPost \&quot;1\&quot; -- \&quot;*\&quot; Review\n\n&#39; ================= REPORT =================\nclass Report {\n  id: String\n  userId: String\n  targetId: String\n  type: ReportType\n  reason: String\n  status: ReportStatus\n  createdAt: LocalDateTime\n}\n\nUser \&quot;1\&quot; -- \&quot;*\&quot; Report\n\n&#39; ================= ROOM HISTORY =================\nclass RoomHistory {\n  id: String\n  userId: String\n  postId: String\n  viewedAt: LocalDateTime\n}\n\nUser \&quot;1\&quot; -- \&quot;*\&quot; RoomHistory\nPost \&quot;1\&quot; -- \&quot;*\&quot; RoomHistory\n\n&#39; ================= BOOST =================\nclass Boost {\n  id: String\n  postId: String\n  landlordId: String\n  price: double\n  startTime: LocalDateTime\n  endTime: LocalDateTime\n  active: boolean\n}\n\nPost \&quot;1\&quot; -- \&quot;*\&quot; Boost\n\n&#39; ================= PACKAGE =================\nclass Package {\n  id: String\n  name: String\n  type: PackageType\n  maxPosts: int\n  durationDays: int\n  price: double\n}\n\n&#39; ================= SUBSCRIPTION =================\nclass Subscription {\n  id: String\n  landlordId: String\n  packageId: String\n  remainingPosts: int\n  startDate: LocalDateTime\n  endDate: LocalDateTime\n  active: boolean\n}\n\nUser \&quot;1\&quot; -- \&quot;1\&quot; Subscription\nPackage \&quot;1\&quot; -- \&quot;*\&quot; Subscription\n\n&#39; ================= TRANSACTION =================\nclass Transaction {\n  id: String\n  landlordId: String\n  targetId: String\n  amount: double\n  paymentMethod: String\n  status: TransactionStatus\n  createdAt: LocalDateTime\n}\n\nUser \&quot;1\&quot; -- \&quot;*\&quot; Transaction\n\n&#39; ================= PAYMENT =================\nclass Payment {\n  id: String\n  transactionId: String\n  vnp_TxnRef: String\n  vnp_TransactionNo: String\n  vnp_OrderInfo: String\n  vnp_ResponseCode: String\n  vnp_BankCode: String\n  amount: double\n  payDate: LocalDateTime\n}\n\nTransaction \&quot;1\&quot; -- \&quot;1\&quot; Payment\n\n&#39; ================= VOUCHER =================\nclass Voucher {\n  id: String\n  code: String\n  discount: double\n  expiredAt: LocalDateTime\n}\n\n&#39; ================= OTP =================\nclass OtpVerification {\n  id: String\n  email: String\n  otpCode: String\n  expiredAt: LocalDateTime\n}\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="gtRnyMREBAxWwlBbQ16G-1">
